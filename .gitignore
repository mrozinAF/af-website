# Dependencies
/node_modules
/.pnp
.pnp.js

# Compiled Sanity Studio
/dist

# Temporary Sanity runtime, generated by the CLI on every dev server start
/.sanity

# Logs
/logs
*.log

# Coverage directory used by testing tools
/coverage

# Misc
.DS_Store
*.pem

# Typescript
*.tsbuildinfo

# Dotenv and similar local-only files
*.local

# Source assets & design handoffs (kept in Sanity, not in git — root-level only)
/*.zip
/*.mp4
/*.mov
/*.png
/*.jpeg
/*.jpg
/changes.html
