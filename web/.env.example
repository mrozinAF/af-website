# Copy this file to `.env.local` (in the web/ folder) to run the frontend.
# These values are public and connect the site to the Sanity project.
NEXT_PUBLIC_SANITY_PROJECT_ID=xk0vwazc
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-02-01

# Optional: a read token enables live/preview of draft content.
# Create one at https://www.sanity.io/manage (Viewer role) and uncomment:
# SANITY_API_READ_TOKEN=
